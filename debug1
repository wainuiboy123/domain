-- PERIPHERAL NAME FINDER (for modded / double chests)
-- Run this directly on the turtle.

print("Peripherals visible to this turtle:")
print("")

local names = peripheral.getNames()
if #names == 0 then
  print("No peripherals found at all - is the turtle an ADVANCED/CRAFTY turtle")
  print("with peripheral access, and is anything actually touching it?")
  return
end

for _, name in ipairs(names) do
  local ptype = peripheral.getType(name)
  print(name .. "   (type: " .. tostring(ptype) .. ")")
end

print("")
print("Look for an inventory-type entry above (chest/barrel/etc).")
print("If its name is a plain compass word (north/south/east/west/up/down),")
print("that word IS your PUSH_DIRECTION.")
print("")
print("If instead it's something like 'ironchest:diamond_chest_0' or similar")
print("modded name, THAT full string is what needs to go in PUSH_DIRECTION -")
print("compass words won't work for it.")
print("")
print("Now testing a real transfer with each name found above...")
print("")

local items = nil
local sourceName = nil
for _, name in ipairs(names) do
  local ptype = peripheral.getType(name)
  if ptype and (ptype:find("chest") or ptype:find("barrel") or ptype:find("inventory")) then
    local p = peripheral.wrap(name)
    if p and p.list then
      local list = p.list()
      if next(list) then
        items = list
        sourceName = name
        break
      end
    end
  end
end

if not sourceName then
  print("Couldn't find a non-empty inventory peripheral to test with.")
  print("Make sure the chest has at least one item in it, then re-run.")
  return
end

local chest = peripheral.wrap(sourceName)
local testSlot = next(items)
print("Testing with peripheral '" .. sourceName .. "', slot " .. testSlot .. " (" .. items[testSlot].name .. ")")

local ok, result = pcall(function()
  return chest.pushItems(sourceName, testSlot, 1, 15) -- wrong direction test skipped; see below
end)

-- The real test: try pushing FROM the chest TO the turtle using every
-- name we found as the "toName" (the turtle itself might show up in
-- this list if it's peripheral-accessible, or we fall back to compass).
local candidates = {}
for _, n in ipairs(names) do table.insert(candidates, n) end
for _, d in ipairs({"north","south","east","west","up","down"}) do table.insert(candidates, d) end

local found = nil
for _, candidate in ipairs(candidates) do
  local ok2, result2 = pcall(function()
    return chest.pushItems(candidate, testSlot, 1, 15)
  end)
  if ok2 and result2 and result2 > 0 then
    print(candidate .. "  ->  SUCCESS")
    found = candidate
    chest.pullItems(candidate, 15, 1, testSlot)
    break
  end
end

print("")
if found then
  print("=====================================")
  print("Use these in your real script:")
  print('local CHEST_SIDE = "' .. sourceName .. '"   -- or keep your current wrap side if it already worked for chest.list()')
  print('local PUSH_DIRECTION = "' .. found .. '"')
  print("=====================================")
else
  print("Still nothing worked. Paste me the full list of peripheral names")
  print("printed above and I'll take a closer look - this is a good sign")
  print("the mod is using a non-standard inventory setup.")
end
