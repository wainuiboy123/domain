-- ITEM DETAIL DUMPER
-- Run this on the turtle. It finds a printed page in the chest, pulls
-- one into the turtle temporarily, and prints EVERY field CC:Tweaked
-- returns for it (detailed = true), so we can see what the title field
-- is actually called.

local CHEST_SIDE = "left"
local PUSH_DIRECTION = "up"  -- <<< set this to whatever worked for you
local PAGE_ITEM = "computercraft:printed_page"

local chest = peripheral.wrap(CHEST_SIDE)
if not chest then
  print("No chest found on side: " .. CHEST_SIDE)
  return
end

local items = chest.list()
local pageSlot = nil
for slot, item in pairs(items) do
  if item.name == PAGE_ITEM then
    pageSlot = slot
    break
  end
end

if not pageSlot then
  print("No " .. PAGE_ITEM .. " found in the chest - put one in and re-run.")
  return
end

print("Found a printed page in chest slot " .. pageSlot .. ", pulling it in to inspect...")

local moved = chest.pushItems(PUSH_DIRECTION, pageSlot, 1, 15)
if moved == 0 then
  print("Couldn't pull it - check CHEST_SIDE/PUSH_DIRECTION at the top of this file.")
  return
end

print("")
print("===== turtle.getItemDetail(15, true) =====")
local detail = turtle.getItemDetail(15, true)
print(textutils.serialize(detail))

print("")
print("===== chest.getItemDetail(pageSlot, true) [for comparison] =====")
-- put it back first isn't needed for this call, chest slot may now be empty
-- so we compare using the turtle-held copy's chest-side view isn't possible;
-- this just shows what the external peripheral sees for OTHER pages if any remain
local remaining = chest.list()
local otherSlot = nil
for slot, item in pairs(remaining) do
  if item.name == PAGE_ITEM then
    otherSlot = slot
    break
  end
end
if otherSlot then
  local chestDetail = chest.getItemDetail(otherSlot, true)
  print(textutils.serialize(chestDetail))
else
  print("(no other page left in chest to compare against - that's fine, ignore this section)")
end

-- put the borrowed page back
chest.pullItems(PUSH_DIRECTION, 15, 1, pageSlot)
print("")
print("Page returned to the chest.")
